# ==============================================================================
# JWT (JSON Web Token) Configuration
# ==============================================================================
# Used by: user-service, securities-service
# ==============================================================================

# Secret key for signing JWT tokens (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Token issuer identifier
JWT_ISSUER=zov-deneg-services

# Token audience (who the token is intended for)
JWT_AUDIENCE=zov-deneg

# Access token TTL in seconds (900 = 15 minutes)
JWT_ACCESS_TTL_SEC=900

# Refresh token TTL in days (30 days)
JWT_REFRESH_TTL_DAYS=30

# Realm for authentication challenges
JWT_REALM=zov-deneg-services
