# ==============================================================================
# ClickHouse Database Configuration
# ==============================================================================
# Used by: securities-service
# ==============================================================================

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT_HTTP=8123
CLICKHOUSE_PORT_NATIVE=9000
CLICKHOUSE_DB=securities
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=securities_pass

# ==============================================================================
# ClickHouse Connection Pool Configuration
# ==============================================================================

# Maximum number of connections in the pool
CLICKHOUSE_POOL_MAX_SIZE=10

# Minimum number of idle connections to maintain
CLICKHOUSE_POOL_MIN_IDLE=2

# Connection timeout in milliseconds (30 seconds)
CLICKHOUSE_POOL_CONNECTION_TIMEOUT=30000

# Idle timeout in milliseconds (10 minutes)
CLICKHOUSE_POOL_IDLE_TIMEOUT=600000

# Maximum connection lifetime in milliseconds (30 minutes)
CLICKHOUSE_POOL_MAX_LIFETIME=1800000
