# ==============================================================================
# User Service Configuration
# ==============================================================================
# Used by: user-service
# ==============================================================================

# Securities Service URL for inter-service communication
# Default points to the internal Docker network service name
SECURITIES_SERVICE_URL=http://zov-securities-service:8080

# HTTP client settings
SECURITIES_SERVICE_CONNECT_TIMEOUT=5000
SECURITIES_SERVICE_REQUEST_TIMEOUT=10000
SECURITIES_SERVICE_MAX_CONNECTIONS=10
