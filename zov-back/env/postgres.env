# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================
# Used by: user-service
# ==============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=userservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_password_123
POSTGRES_DRIVER=org.postgresql.Driver

# Database URL for JDBC connections
POSTGRES_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Optional: Use embedded H2 database for testing (default: false)
# DATABASE_USE_EMBEDDED=false
